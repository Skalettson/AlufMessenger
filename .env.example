# Example environment variable names only — no real values.
# Copy to `.env` locally for private development; do not commit `.env`.

# Database
# DATABASE_URL=

# Cache / broker
# REDIS_URL=
# NATS_URL=

# Object storage (S3-compatible)
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# Public base URL for browser-accessible media (your CDN or gateway)
# MINIO_PUBLIC_URL=

# JWT / crypto (paths or inline material as used by your deployment)
# JWT_PRIVATE_KEY_PATH=
# JWT_PUBLIC_KEY_PATH=

# Web / realtime (names only; values depend on environment)
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_WS_URL=
# Comma-separated hostnames for absolute media URLs that should be rewritten to local paths (optional)
# NEXT_PUBLIC_MEDIA_OWN_HOSTS=

# Next.js → API Gateway proxy (private / local dev)
# API_GATEWAY_URL=

# Firebase web client (FCM) — set in private CI from secrets
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Optional: extra CSP connect-src origins (comma-separated)
# CSP_CONNECT_EXTRA=
